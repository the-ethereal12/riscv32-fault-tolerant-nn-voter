<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tmr_tb_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tmr_tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="80.920 ns"></ZoomEndTime>
      <Cursor1Time time="320.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="244"></NameColumnWidth>
      <ValueColumnWidth column_width="232"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="6" />
   <wvobject fp_name="/tmr_tb/clk" type="logic">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject fp_name="/tmr_tb/reset" type="logic">
      <obj_property name="ElementShortName">reset</obj_property>
      <obj_property name="ObjectShortName">reset</obj_property>
   </wvobject>
   <wvobject fp_name="/tmr_tb/fault_inject" type="array">
      <obj_property name="ElementShortName">fault_inject[31:0]</obj_property>
      <obj_property name="ObjectShortName">fault_inject[31:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tmr_tb/fault_enable" type="logic">
      <obj_property name="ElementShortName">fault_enable</obj_property>
      <obj_property name="ObjectShortName">fault_enable</obj_property>
   </wvobject>
   <wvobject fp_name="/tmr_tb/pc_out_debug" type="array">
      <obj_property name="ElementShortName">pc_out_debug[31:0]</obj_property>
      <obj_property name="ObjectShortName">pc_out_debug[31:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tmr_tb/fault_detected" type="logic">
      <obj_property name="ElementShortName">fault_detected</obj_property>
      <obj_property name="ObjectShortName">fault_detected</obj_property>
   </wvobject>
</wave_config>
